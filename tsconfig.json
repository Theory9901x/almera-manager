{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "paths": { "@/*": ["./src/*"] },
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "5.0",
    "allowArbitraryExtensions": true
  },
  "include": ["src/main.tsx", "src/App.tsx", "src/platform", "src/shared", "src/modules/almera", "vite.config.ts"]
}
